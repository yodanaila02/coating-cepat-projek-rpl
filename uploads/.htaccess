# KEAMANAN — folder uploads: PHP tidak dieksekusi, listing diblokir
# Kompatibel InfinityFree (LiteSpeed)

Options -Indexes

# Blokir eksekusi PHP di folder uploads
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|shtml)$">
  Require all denied
</FilesMatch>

# Fallback untuk server lama
<IfModule !mod_authz_core.c>
  <FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|shtml)$">
    Order allow,deny
    Deny from all
  </FilesMatch>
</IfModule>
